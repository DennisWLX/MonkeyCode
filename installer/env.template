# MonkeyCode Orchestrator Environment Configuration
# Generated automatically by installer

# ===========================================
# 基础配置
# ===========================================

# 安装目录
INSTALL_DIR=/data/monkeycode_runner

# 宿主机唯一标识
HOST_ID={{.HOST_ID}}
HOST_UUID={{.HOST_UUID}}

# ===========================================
# 认证配置
# ===========================================

# Runner 认证令牌
TOKEN={{.TOKEN}}

# ===========================================
# TaskFlow 服务配置
# ===========================================

# TaskFlow gRPC 连接地址
GRPC_HOST={{.GRPC_HOST}}
GRPC_PORT={{.GRPC_PORT}}
GRPC_URL={{.GRPC_URL}}

# ===========================================
# Docker 配置
# ===========================================

# Docker 网络
DOCKER_NETWORK=monkeycode_runner_network

# ===========================================
# 日志配置
# ===========================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===========================================
# 资源限制
# ===========================================

# 最大 CPU 核心数
MAX_CORES=8

# 最大内存 (MB)
MAX_MEMORY=16384

# ===========================================
# AI 配置
# ===========================================

# OpenAI API 密钥
OPENAI_API_KEY=

# OpenAI API 地址
OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================
# 安全配置
# ===========================================

# API 密钥 (可选)
# API_KEY=
